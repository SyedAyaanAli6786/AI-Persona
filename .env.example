# ── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── GitHub ────────────────────────────────────────────────
GITHUB_USERNAME=SyedAyaanAli6786
GITHUB_TOKEN=ghp_...           # optional but recommended (higher rate limits)

# ── Vapi (Voice Agent) ────────────────────────────────────
VAPI_API_KEY=...
VAPI_PHONE_NUMBER_ID=...       # phone number ID from Vapi dashboard
VAPI_ASSISTANT_ID=             # filled in after running voice/setup_vapi.py

# ── Cal.com (Calendar Booking) ────────────────────────────
CAL_API_KEY=cal_live_...
CAL_EVENT_TYPE_ID=             # numeric ID of your event type in Cal.com
CAL_USERNAME=your-cal-username # your Cal.com username / slug

# ── Backend URL (used by Next.js frontend) ─────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── ChromaDB (auto-configured, override if needed) ────────
CHROMA_PERSIST_DIR=./chroma_db
